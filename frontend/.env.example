# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE BASE DE DATOS
# -----------------------------------------------------------------------------
# [DOCKER]: Usa esta URL para que el backend se conecte al contenedor "db".
DATABASE_URL="mysql://root:root_pass@db:3306/schedule_db"

# [LOCAL/WINDOWS]: Si ejecutas comandos desde tu terminal (npx prisma...), 
# usa el puerto mapeado en docker-compose (13306):
# DATABASE_URL="mysql://root:root_pass@localhost:13306/schedule_db"

# [CAMBIO PRODUCCIÓN]: Cambia esta URL por la de tu servidor MySQL real.
# DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# -----------------------------------------------------------------------------
# AUTENTICACIÓN (JWT)
# -----------------------------------------------------------------------------
# [CAMBIO PRODUCCIÓN]: ¡OBLIGATORIO! Cambia estos por secretos largos y complejos.
JWT_SECRET="your-very-long-random-secret-here-for-access-tokens-1234567890"
JWT_REFRESH_SECRET="another-different-very-long-secret-for-refresh-tokens-0987654321"

# Tiempos de expiración (formatos aceptados por zeit/ms, e.g. 15m, 1h, 7d)
ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"

# -----------------------------------------------------------------------------
# SERVER SETTINGS
# -----------------------------------------------------------------------------
PORT=13001
# [CAMBIO PRODUCCIÓN]: Cambia a "production" cuando despliegues.
NODE_ENV="development" # development, production, test

# [CAMBIO PRODUCCIÓN]: Incluye la IP o el dominio de tu servidor de Intranet.
CORS_ORIGIN="http://localhost:15173,http://127.0.0.1:15173"

# -----------------------------------------------------------------------------
# INITIAL SEED DATA (Used by prisma/seed.ts)
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@company.com"
SEED_ADMIN_PASSWORD="AdminPass123!"
SEED_ADMIN_NAME="System Administrator"

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DEL FRONTEND (Vite)
# -----------------------------------------------------------------------------
# URL base para las peticiones a la API del Backend.
VITE_API_URL="http://localhost:13001"