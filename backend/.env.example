# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# For Docker/Development using the provided docker-compose.yml:
DATABASE_URL="mysql://root:root_pass@db:3306/schedule_db"

# Format for external MySQL:
# DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# -----------------------------------------------------------------------------
# SECURITY & AUTHENTICATION (JWT)
# -----------------------------------------------------------------------------
# Genera secretos largos y aleatorios (mínimo 64 caracteres recomendados para producción)
JWT_SECRET="your-very-long-random-secret-here-for-access-tokens-1234567890"
JWT_REFRESH_SECRET="another-different-very-long-secret-for-refresh-tokens-0987654321"

# Tiempos de expiración (formatos aceptados por zeit/ms, e.g. 15m, 1h, 7d)
ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"

# -----------------------------------------------------------------------------
# SERVER SETTINGS
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV="development" # development, production, test

# CORS_ORIGIN: lista separada por comas de orígenes permitidos
# NOTA: En modo desarrollo (NODE_ENV != production), el backend permite CUALQUIER
# origen automáticamente para facilitar pruebas en red local/intranet.
CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"

# -----------------------------------------------------------------------------
# INITIAL SEED DATA (Used by npm run db:seed)
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@company.com"
SEED_ADMIN_PASSWORD="AdminPass123!"
SEED_ADMIN_NAME="System Administrator"
