DATABASE_URL="file:./prisma/schedule.db"
JWT_SECRET="your-very-long-random-secret-here-minimum-64-characters-please"
JWT_REFRESH_SECRET="another-different-long-random-secret-here-minimum-64-characters"
ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"
PORT=3001
NODE_ENV="development"
# CORS_ORIGIN acepta una lista separada por comas.
# Produccion/Intranet: usa DNS/IP reales del frontend, por ejemplo:
# CORS_ORIGIN="http://intranet-app:5173,http://10.0.0.25:5173"
# Si publicas frontend+backend bajo el mismo host/proxy, usa solo ese origen.
CORS_ORIGIN="http://localhost:5173"
SEED_ADMIN_EMAIL="admin@company.com"
SEED_ADMIN_PASSWORD="AdminPass123!"
SEED_ADMIN_NAME="System Administrator"
